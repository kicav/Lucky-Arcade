APP_NAME="Lucky Arcade"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://arcade.example.com
APP_TIMEZONE=UTC

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=lucky_arcade
DB_USERNAME=lucky_arcade
DB_PASSWORD=change-this-long-password

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
QUEUE_CONNECTION=redis

MAIL_MAILER=log
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="Lucky Arcade"

ARCADE_BACKUP_KEEP=14
ARCADE_NOTIFICATION_RETENTION_DAYS=90
ARCADE_SECURITY_RETENTION_DAYS=180
ARCADE_OPERATION_RETENTION_DAYS=90
ARCADE_QUEUE_WARNING_THRESHOLD=100

LIVE_POLL_MS=4000
LIVE_EVENT_TTL_SECONDS=21600
LIVE_PRESENCE_WINDOW_MINUTES=5
